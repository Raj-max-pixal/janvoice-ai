# ============================================
# Firebase Configuration
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# 9Router Local Gateway
# ============================================
# Base URL for the local 9Router Gateway (OpenAI-compatible endpoint)
# Default: http://localhost:20128/v1
VITE_9ROUTER_BASE_URL=http://localhost:20128/v1

# API key (only if your gateway requires authentication)
# Leave empty if no auth is needed
VITE_9ROUTER_API_KEY=

# Model override (optional)
# If unset, the app auto-detects from GET /v1/models
# Example: VITE_9ROUTER_MODEL=qwen/qwen3-8b
VITE_9ROUTER_MODEL=